{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zingx",
  "version": "0.1.0",
  "identifier": "com.rhishav.zingx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zingx",
        "width": 1280,
        "height": 800,
        "fullscreen": false,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
